{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "career-portal": {
      "root": "",
      "sourceRoot": "src",
      "projectType": "application",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/career-portal",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              "src/assets",
              "src/favicon.ico",
              "src/static/custom.css",
              "src/static/privacy-policy.html",
              "src/version.txt",
              {
                "glob": "**/*",
                "input": "src/static/i18n/",
                "output": "/i18n/"
              }
            ],
            "styles": ["src/styles.scss"],
            "scripts": []
          },
          "configurations": {
            "static": {
              "baseHref": ".",
              "optimization": true,
              "outputHashing": "none",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": false,
              "budgets": [
                { "type": "anyComponentStyle", "maximumWarning": "6kb" }
              ],
              "assets": [
                "src/assets",
                "src/favicon.ico",
                "src/static/custom.css",
                "src/static/privacy-policy.html",
                "src/version.txt",
                {
                  "input": "src/configuration/static",
                  "output": "/",
                  "glob": "app.json"
                },
                {
                  "glob": "**/*",
                  "input": "src/static/i18n/",
                  "output": "/i18n/"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.static.ts"
                }
              ]
            },
            "qa": {
              "baseHref": ".",
              "optimization": true,
              "outputHashing": "none",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": false,
              "budgets": [
                { "type": "anyComponentStyle", "maximumWarning": "6kb" }
              ],
              "assets": [
                "src/assets",
                "src/favicon.ico",
                "src/static/custom.css",
                "src/static/privacy-policy.html",
                "src/version.txt",
                {
                  "input": "src/configuration/qa",
                  "output": "/",
                  "glob": "app.json"
                },
                {
                  "glob": "**/*",
                  "input": "src/static/i18n/",
                  "output": "/i18n/"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.static.ts"
                }
              ]
            },
            "dynamic": {
              "baseHref": "/",
              "optimization": true,
              "outputHashing": "none",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": false,
              "budgets": [
                { "type": "anyComponentStyle", "maximumWarning": "6kb" }
              ],
              "server": "src/main.server.ts",
              "ssr": {
                "entry": "server.ts"
              },
              "assets": [
                "src/assets",
                "src/favicon.ico",
                "src/static/custom.css",
                "src/static/privacy-policy.html",
                "src/version.txt",
                {
                  "input": "src/configuration/dynamic",
                  "output": "/",
                  "glob": "app.json"
                },
                {
                  "glob": "**/*",
                  "input": "src/static/i18n/",
                  "output": "/i18n/"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.dynamic.ts"
                }
              ]
            }
          }
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "buildTarget": "career-portal:build"
          },
          "configurations": {
            "static": {
              "buildTarget": "career-portal:build:static"
            },
            "qa": {
              "buildTarget": "career-portal:build:qa"
            },
            "dynamic": {
              "buildTarget": "career-portal:build:dynamic"
            }
          }
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "buildTarget": "career-portal:build"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["src/**/*.ts", "src/**/*.html"]
          }
        },
        "cypress-run": {
          "builder": "@cypress/schematic:cypress",
          "options": {
            "devServerTarget": "career-portal:serve:static"
          },
          "configurations": {
            "qa": {
              "devServerTarget": "career-portal:serve:qa"
            }
          }
        },
        "cypress-open": {
          "builder": "@cypress/schematic:cypress",
          "options": {
            "watch": true,
            "headless": false
          }
        },
        "e2e": {
          "builder": "@cypress/schematic:cypress",
          "options": {
            "devServerTarget": "career-portal:serve:static",
            "watch": true,
            "headless": false
          }
        }
      }
    }
  },
  "schematics": {
    "@schematics/angular:component": {
      "prefix": "app",
      "style": "scss"
    },
    "@schematics/angular:directive": {
      "prefix": "app"
    }
  }
}
