# Boostie Career Portal — environment variables
# Copy to .env and fill in values, or set directly in your hosting environment.
# Run `npm run configure` to write these into the static config before building.

# ── Company ────────────────────────────────────────────────────────────────────
COMPANY_NAME=Acme Staffing
COMPANY_WEBSITE=https://acmestaffing.com
COMPANY_LOGO_URL=./assets/logo.png

# ── Bullhorn ───────────────────────────────────────────────────────────────────
BULLHORN_SWIMLANE=91
BULLHORN_CORP_TOKEN=your_corp_token_here
HOSTED_ENDPOINT=https://careers.acmestaffing.com

# ── Boostie ────────────────────────────────────────────────────────────────────
BOOSTIE_CLIENT_ID=your-boostie-client-id-here

# ── Analytics (optional) ───────────────────────────────────────────────────────
GOOGLE_ANALYTICS_TRACKING_ID=
GOOGLE_VERIFICATION_CODE=

# ── Server (dynamic/SSR builds only) ──────────────────────────────────────────
PORT=4000
ALLOWED_HOST=careers.acmestaffing.com
